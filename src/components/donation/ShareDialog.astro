---
interface Props {
  title: string;
  text: string;
}

const { title, text } = Astro.props;
const shareUrl = Astro.url.href;
---

<!-- Share overlay (desktop fallback) -->
<div id="share-dialog" class="share-overlay" aria-hidden="true">
  <div class="share-backdrop"></div>
  <div class="share-sheet">
    <div class="share-header">
      <span class="share-title">Kampagne teilen</span>
      <button id="share-close" class="share-close" aria-label="Schließen">&times;</button>
    </div>
    <div class="share-options">
      <button class="share-option" data-action="whatsapp">
        <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        <span>WhatsApp</span>
      </button>
      <button class="share-option" data-action="email">
        <svg class="share-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4l-10 8L2 4"/></svg>
        <span>Email</span>
      </button>
      <button class="share-option" data-action="facebook">
        <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        <span>Facebook</span>
      </button>
      <button class="share-option" data-action="x">
        <svg class="share-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        <span>X</span>
      </button>
      <button class="share-option" data-action="copy">
        <svg class="share-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        <span>Link kopieren</span>
      </button>
    </div>
    <div id="share-copied" class="share-copied" aria-hidden="true">Link kopiert!</div>
  </div>
</div>

<script define:vars={{ title, text, shareUrl }}>
  const shareData = { title, text, url: shareUrl };

  function triggerShare() {
    // Use native Web Share API on supported devices (mobile)
    if (navigator.share) {
      navigator.share(shareData).catch(() => {});
      return;
    }
    // Desktop fallback: show dialog
    openDialog();
  }

  function openDialog() {
    const dialog = document.getElementById('share-dialog');
    dialog.setAttribute('aria-hidden', 'false');
  }

  function closeDialog() {
    const dialog = document.getElementById('share-dialog');
    dialog.setAttribute('aria-hidden', 'true');
  }

  // Listen for share events from any button
  window.addEventListener('trigger-share', triggerShare);

  // Close button
  document.getElementById('share-close').addEventListener('click', closeDialog);

  // Backdrop click
  document.querySelector('.share-backdrop').addEventListener('click', closeDialog);

  // Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDialog();
  });

  // Share option actions
  document.querySelectorAll('.share-option').forEach((btn) => {
    btn.addEventListener('click', () => {
      const action = btn.dataset.action;
      const encoded = encodeURIComponent(shareUrl);
      const encodedText = encodeURIComponent(text + '\n\n' + shareUrl);

      switch (action) {
        case 'whatsapp':
          window.open(`https://wa.me/?text=${encodedText}`, '_blank');
          closeDialog();
          break;
        case 'email':
          window.location.href = `mailto:?subject=${encodeURIComponent(title)}&body=${encodedText}`;
          closeDialog();
          break;
        case 'facebook':
          window.open(`https://www.facebook.com/sharer/sharer.php?u=${encoded}`, '_blank', 'width=600,height=400');
          closeDialog();
          break;
        case 'x':
          window.open(`https://x.com/intent/tweet?url=${encoded}&text=${encodeURIComponent(text)}`, '_blank', 'width=600,height=400');
          closeDialog();
          break;
        case 'copy':
          navigator.clipboard.writeText(shareUrl).then(() => {
            const copied = document.getElementById('share-copied');
            copied.setAttribute('aria-hidden', 'false');
            setTimeout(() => copied.setAttribute('aria-hidden', 'true'), 2000);
          });
          break;
      }
    });
  });
</script>

<style>
  .share-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    transition: opacity 0.2s ease, visibility 0.2s ease;
  }
  .share-overlay[aria-hidden='true'] {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  .share-overlay[aria-hidden='false'] {
    opacity: 1;
    visibility: visible;
  }
  .share-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
  }
  .share-sheet {
    position: relative;
    width: 100%;
    max-width: 420px;
    background: var(--color-surface);
    border-radius: 16px 16px 0 0;
    padding: 1.25rem 1.25rem 1.5rem;
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.12);
  }
  @media (min-width: 640px) {
    .share-overlay {
      align-items: center;
    }
    .share-sheet {
      border-radius: 16px;
      margin-bottom: 0;
    }
  }
  .share-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }
  .share-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .share-close {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    color: var(--color-text-mid);
    background: none;
    border: none;
    cursor: pointer;
    border-radius: 50%;
  }
  .share-close:hover {
    background: var(--color-accent-soft);
  }
  .share-options {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .share-option {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    border: none;
    background: none;
    cursor: pointer;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    transition: background 0.15s ease;
  }
  .share-option:hover {
    background: var(--color-accent-soft);
  }
  .share-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }
  .share-copied {
    text-align: center;
    padding: 0.5rem;
    margin-top: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: #16a34a;
    transition: opacity 0.2s ease;
  }
  .share-copied[aria-hidden='true'] {
    opacity: 0;
  }
  .share-copied[aria-hidden='false'] {
    opacity: 1;
  }
</style>
