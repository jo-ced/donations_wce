---
import Label from "../Label.astro";
import { useTranslations, type Lang } from "../../i18n/utils";

interface Props {
    title: string;
    subtitle: string;
    organizerName: string;
    organizerRole: string;
    intro?: string;
    lang: Lang;
}

const { title, subtitle, organizerName, organizerRole, intro, lang } = Astro.props;
const t = useTranslations(lang);
---

<section
    class="px-5 pt-4 pb-10 border-b border-border lg:flex lg:justify-between lg:items-center"
>
    <div>
        <Label>{t('section.campaign')}</Label>
        <h1 class="text-2xl lg:text-3xl font-bold text-text leading-snug m-0">{title}</h1>
        <p class="mt-2 text-base text-text-mid m-0">{subtitle}</p>
    </div>
    <div>
        {intro && <p class="mt-3 text-[15px] leading-relaxed text-text-mid m-0">{intro}</p>}
        <div class="mt-4 flex items-center gap-3 lg:min-w-92 lg:justify-end">
            <img
                src="/dream-of-hearing/images/logo/wce-logo.webp"
                alt={organizerName}
                class="w-10 h-10 rounded-full object-cover shrink-0"
            />
            <div>
                <span class="text-sm font-semibold text-text block"
                    >{organizerName}</span
                >
                <span class="text-[12px] text-text-light block mt-0.5"
                    >{organizerRole}</span
                >
            </div>
        </div>
    </div>
</section>
