---
import Label from "../Label.astro";
import { useTranslations, type Lang } from "../../i18n/utils";

interface Props {
    goal: number;
    currency: string;
    lang: Lang;
}

const { goal, currency, lang } = Astro.props;
const t = useTranslations(lang);
---

<section
    class="px-5 py-4 border-b border-border"
    x-data={`{
        raised: 0,
        goal: ${goal},
        countUp(target) {
            const duration = 1200;
            const start = performance.now();
            const step = (now) => {
                const t = Math.min((now - start) / duration, 1);
                const ease = 1 - Math.pow(1 - t, 3);
                this.raised = Math.round(ease * target);
                if (t < 1) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
        }
    }`}
    @donations-loaded.window="countUp($event.detail.raised)"
>
    <Label>{t('section.progress')}</Label>
    <div class="flex justify-between items-baseline mb-2">
        <span class="text-[26px] font-bold text-text">
            {currency}<span x-text="raised.toLocaleString()">0</span>
        </span>
        <span class="text-sm text-text-light">
            {t('progress.of')} {currency}{(goal / 1000).toFixed(0)}{t('progress.thousands')} &middot; <span
                class="text-text"
                x-text="(Math.min((raised / goal) * 100, 100)).toFixed(1).replace('.', ',') + '%'"
                >0,0%</span
            >
        </span>
    </div>
    <div class="h-1.5 rounded-[3px] bg-accent-soft">
        <div
            class="h-full rounded-[3px] bg-[#c2552d] transition-[width] duration-800 ease-out"
            style="width: 0px;"
            :style="`width: ${Math.min(Math.round((raised / goal) * 100), 100)}%`"
        >
        </div>
    </div>
</section>
