---
import Button from '../Button.astro';

interface Props {
  primaryLabel: string;
  secondaryLabel: string;
}

const { primaryLabel, secondaryLabel } = Astro.props;
---

<div class="fixed bottom-0 left-0 right-0 z-50 bg-surface border-t border-border px-5 py-3 flex gap-2.5">
  <button
    onclick="window.dispatchEvent(new CustomEvent('trigger-share'))"
    class="flex-1 px-5 py-3 rounded-[10px] text-[13px] font-semibold cursor-pointer bg-transparent border border-border text-text-mid"
  >{secondaryLabel}</button>
  <button
    onclick="window.dispatchEvent(new CustomEvent('open-stripe'))"
    class="flex-1 px-5 py-3 rounded-[10px] text-[13px] font-semibold tracking-[0.3px] cursor-pointer border-none bg-accent text-white"
  >{primaryLabel}</button>
</div>
