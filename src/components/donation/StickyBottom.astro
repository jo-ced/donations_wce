---
import { useTranslations, type Lang } from "../../i18n/utils";

interface Props {
    goal: number;
    currency: string;
    lang: Lang;
}

const { goal, currency, lang } = Astro.props;
const t = useTranslations(lang);
---

<div
    class="fixed bottom-0 left-0 right-0 z-50 bg-surface border-t border-border px-5 pt-2.5 pb-3 flex flex-col gap-2.5"
    x-data={`{ raised: 0, goal: ${goal} }`}
    @donations-loaded.window="raised = $event.detail.raised"
>
    <div>
        <div class="flex justify-between items-baseline mb-1.5">
            <span class="text-[17px] font-bold text-text">
                {currency}<span x-text="raised.toLocaleString()">0</span>
            </span>
            <span class="text-[13px] text-text-light">
                {t('progress.of')} {currency}{(goal / 1000).toFixed(1)}{t('progress.thousands')} &middot; <span
                    class="text-text"
                    x-text="(Math.min((raised / goal) * 100, 100)).toFixed(1).replace('.', ',') + '%'"
                    >0,0%</span
                >
            </span>
        </div>
        <div class="h-1.5 rounded-[3px] bg-accent-soft my-1">
            <div
                class="h-full rounded-[3px] bg-[#c2552d] transition-[width] duration-600 ease-out"
                :style="`width: ${Math.min(Math.round((raised / goal) * 100), 100)}%`"
            >
            </div>
        </div>
    </div>
    <div class="flex gap-2.5">
        <button
            onclick="window.dispatchEvent(new CustomEvent('trigger-share'))"
            class="flex-1 px-5 py-3 rounded-[10px] text-[15px] font-semibold cursor-pointer bg-transparent border border-border text-text-mid"
            >{t('cta.share')}</button
        >
        <button
            onclick="window.dispatchEvent(new CustomEvent('open-stripe'))"
            class="flex-1 px-5 py-3 rounded-[10px] text-[15px] font-semibold tracking-[0.3px] cursor-pointer border-none bg-accent text-white"
            >{t('cta.donate')}</button
        >
    </div>
</div>
