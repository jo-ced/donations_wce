---
import Label from "../Label.astro";
import { useTranslations, type Lang } from "../../i18n/utils";

interface Props {
    currency: string;
    lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const tabLatest = t('donations.tab.latest');
const tabTop = t('donations.tab.top');
const i18nDonations = {
  anonymous: t('donations.anonymous'),
  empty: t('donations.empty'),
  showMore: t('donations.showMore'),
  showLess: t('donations.showLess'),
  justNow: t('donations.timeAgo.justNow'),
  before: t('donations.timeAgo.before'),
  daySingular: t('donations.timeAgo.daysSingular'),
  dayPlural: t('donations.timeAgo.daysPlural'),
  hourSingular: t('donations.timeAgo.hoursSingular'),
  hourPlural: t('donations.timeAgo.hoursPlural'),
  minuteSingular: t('donations.timeAgo.minutesSingular'),
  minutePlural: t('donations.timeAgo.minutesPlural'),
};
// For German: "vor N Tag(en)" → before + n + singular/plural
// For English: "N day(s) ago" → n + singular/plural + "ago" (before is '')
const isRtlTime = lang === 'de'; // before word comes first
---

<section
    class="px-5 py-4 border-b border-border"
    x-data={`{
      activeTab: '${tabLatest}',
      showAll: 10,
      showTop: 10,
      loading: true,
      donors: [],

      get visibleDonors() {
        return this.donors.filter(d => !d.anonymous).sort((a, b) => b.created - a.created);
      },
      get topDonors() {
        return [...this.visibleDonors].sort((a, b) => b.amount - a.amount);
      },
      get currentList() {
        return this.activeTab === '${tabTop}' ? this.topDonors : this.visibleDonors;
      },
      get currentLimit() {
        return this.activeTab === '${tabTop}' ? this.showTop : this.showAll;
      },

      timeAgo(created) {
        const diff = Math.floor(Date.now() / 1000) - created;
        const minutes = Math.floor(diff / 60);
        const hours = Math.floor(diff / 3600);
        const days = Math.floor(diff / 86400);
        const i18n = ${JSON.stringify(i18nDonations)};
        const isRtl = ${JSON.stringify(isRtlTime)};
        function fmt(n, singular, plural) {
          const unit = n === 1 ? singular : plural;
          return isRtl ? (i18n.before + ' ' + n + ' ' + unit) : (n + ' ' + unit + (i18n.before ? ' ' + i18n.before : ''));
        }
        if (days > 0) return fmt(days, i18n.daySingular, i18n.dayPlural);
        if (hours > 0) return fmt(hours, i18n.hourSingular, i18n.hourPlural);
        if (minutes > 0) return fmt(minutes, i18n.minuteSingular, i18n.minutePlural);
        return i18n.justNow;
      },
      initials(name) {
        return name.split(/\\s+/).filter(Boolean).map(w => w[0].toUpperCase()).slice(0, 2).join('');
      },

      async init() {
        try {
          const res = await fetch('/api/donations.json');
          const json = await res.json();
          const i18n = ${JSON.stringify(i18nDonations)};
          this.donors = (json.data || []).map(d => ({
            name: d.donor.name ?? i18n.anonymous,
            amount: (d.amount / 100).toFixed(2),
            anonymous: d.donor.anonymous,
            created: d.created,
          }));
          window.dispatchEvent(new CustomEvent('donations-loaded', {
            detail: { raised: json.data.reduce((s, d) => s + d.amount, 0) / 100, count: json.data.length }
          }));
        } catch { }
        this.loading = false;
      }
    }`}
>
    <div class="flex justify-between items-center">
        <Label>
            {t('section.donations')} <span x-show="!loading"
                >&middot; <span x-text="donors.length"></span></span
            >
        </Label>
        <div class="flex gap-1">
            <template x-for={`tab in ['${tabLatest}', '${tabTop}']`}>
                <button
                    x-text="tab"
                    @click="activeTab = tab"
                    :class="activeTab === tab ? 'bg-accent text-white' : 'bg-transparent text-text-light'"
                    class="px-2.5 py-1 rounded-[6px] border-none text-sm font-semibold cursor-pointer capitalize"
                ></button>
            </template>
        </div>
    </div>
    <span class="text-xs text-text-light italic block my-1">
        {t('donations.disclaimer')}
    </span>

    <!-- Loading skeleton -->
    <div x-show="loading">
        <template x-for="i in 3">
            <div class="flex items-center gap-2.5 py-2 animate-pulse">
                <div
                    class="w-[30px] h-[30px] rounded-full bg-[#e8e6e0] shrink-0"
                >
                </div>
                <div class="flex-1">
                    <div class="h-3 w-24 bg-[#e8e6e0] rounded mb-1"></div>
                    <div class="h-2.5 w-16 bg-[#f0ede8] rounded"></div>
                </div>
                <div class="h-3 w-10 bg-[#e8e6e0] rounded"></div>
            </div>
        </template>
    </div>

    <!-- Empty state -->
    <div
        x-show="!loading && donors.length === 0"
        x-cloak
        class="py-8 text-center"
    >
        <p class="text-sm text-text-light">
            {t('donations.empty')}
        </p>
    </div>

    <!-- Donor list -->
    <div x-show="!loading && donors.length > 0" x-cloak>
        <template x-for="(donor, i) in currentList" :key="i">
            <div
                x-show="i < currentLimit"
                class="flex items-center gap-2.5 py-2"
            >
                <div
                    style="width: 34px; height: 34px; font-size: 13px; background: linear-gradient(135deg, #c2552d, #e0845e);"
                    class="rounded-full shrink-0 flex items-center justify-center text-white font-semibold leading-none select-none"
                    x-text="initials(donor.name)"
                >
                </div>
                <div class="flex-1">
                    <span
                        class="text-sm text-text block"
                        x-text="donor.name"></span>
                    <span
                        class="text-xs text-text-light block mt-0.5"
                        x-text="timeAgo(donor.created)"></span>
                </div>
                <span
                    class="text-sm font-semibold text-text-mid"
                    x-text="'€' + donor.amount"></span>
            </div>
        </template>

        <!-- Show more / less (Latest tab) -->
        <button
            x-show={`activeTab === '${tabLatest}' && showAll < visibleDonors.length`}
            @click="showAll = Math.min(showAll + 10, visibleDonors.length)"
            class="mt-3 bg-transparent border-none p-0 text-xs font-semibold cursor-pointer flex items-center gap-1"
            style="color: #c2552d;"
        >
            <span x-text={`\`${t('donations.showMore')} (\${visibleDonors.length - showAll})\``}
            ></span>
            <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="6 9 12 15 18 9"></polyline></svg
            >
        </button>
        <button
            x-show={`activeTab === '${tabLatest}' && showAll > 10`}
            @click="showAll = 10"
            class="mt-3 bg-transparent border-none p-0 text-xs font-semibold cursor-pointer flex items-center gap-1"
            style="color: #c2552d;"
        >
            <span>{t('donations.showLess')}</span>
            <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="rotate-180"
                ><polyline points="6 9 12 15 18 9"></polyline></svg
            >
        </button>

        <!-- Show more / less (Top tab) -->
        <button
            x-show={`activeTab === '${tabTop}' && showTop < topDonors.length`}
            @click="showTop = Math.min(showTop + 10, topDonors.length)"
            class="mt-3 bg-transparent border-none p-0 text-xs font-semibold cursor-pointer flex items-center gap-1"
            style="color: #c2552d;"
        >
            <span x-text={`\`${t('donations.showMore')} (\${topDonors.length - showTop})\``}
            ></span>
            <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="6 9 12 15 18 9"></polyline></svg
            >
        </button>
        <button
            x-show={`activeTab === '${tabTop}' && showTop > 10`}
            @click="showTop = 10"
            class="mt-3 bg-transparent border-none p-0 text-xs font-semibold cursor-pointer flex items-center gap-1"
            style="color: #c2552d;"
        >
            <span>{t('donations.showLess')}</span>
            <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="rotate-180"
                ><polyline points="6 9 12 15 18 9"></polyline></svg
            >
        </button>
    </div>
</section>
