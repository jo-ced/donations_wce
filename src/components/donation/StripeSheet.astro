---
// @ts-nocheck
import { useTranslations, type Lang } from "../../i18n/utils";

interface Props {
    orgName: string;
    campaignName: string;
    recipientName: string;
    lang: Lang;
}

const { orgName, campaignName, recipientName, lang } = Astro.props;
const t = useTranslations(lang);

const amountsEnv = import.meta.env.PUBLIC_DONATION_AMOUNTS || '10,25,50,100';
const amounts = amountsEnv.split(',').map((a: string) => parseInt(a, 10));


const i18n = {
  errorGeneric: t('stripe.errorGeneric'),
  errorConnection: t('stripe.errorConnection'),
  donateButton: t('stripe.donateButton'),
  yourNameFallback: t('stripe.yourNameFallback'),
  displayNamePlaceholder: t('stripe.displayNamePlaceholder'),
};
---

<script is:inline define:vars={{ amounts, i18n, lang }}>
document.addEventListener('alpine:init', () => {
  Alpine.data('donationSheet', () => ({
    open: false,
    amounts: amounts,
    qrUrl: '',
    donateButtonSuffix: i18n.donateButton,
    yourNameFallback: i18n.yourNameFallback,
    displayNamePlaceholder: i18n.displayNamePlaceholder,
    amount: 25,
    customAmount: '',
    donorName: '',
    shareOnList: true,
    displayName: '',
    coverFees: false,
    processing: false,
    error: '',
    paymentMethod: 'sepa_debit',
    showFeeInfo: false,
    isDragging: false,
    dragStartY: 0,

    dragStart(e) {
      this.$refs.sheet.style.transition = 'none';
      this.isDragging = true;
      this.dragStartY = e.touches[0].clientY;
    },
    dragMove(e) {
      if (!this.isDragging) return;
      const delta = e.touches[0].clientY - this.dragStartY;
      if (delta > 0) {
        this.$refs.sheet.style.transform = 'translateY(' + delta + 'px)';
      }
    },
    dragEnd() {
      if (!this.isDragging) return;
      this.isDragging = false;
      const sheet = this.$refs.sheet;
      const match = sheet.style.transform.match(/translateY\((\d+(?:\.\d+)?)px\)/);
      const delta = match ? parseFloat(match[1]) : 0;
      if (delta > 100) {
        sheet.style.transition = 'transform 0.28s ease-in';
        sheet.style.transform = 'translateY(110%)';
        setTimeout(() => { this.open = false; }, 260);
      } else {
        sheet.style.transition = 'transform 0.4s cubic-bezier(0.32,0.72,0,1)';
        sheet.style.transform = 'translateY(0)';
        setTimeout(() => {
          sheet.style.transition = '';
          sheet.style.transform = '';
        }, 420);
      }
    },

    get finalAmount() {
      return this.customAmount ? (parseInt(this.customAmount) || 0) : this.amount;
    },
    async init() {
      if (window.__epcQr) {
        this.qrUrl = await window.__epcQr(this.finalAmount);
        this.$watch('finalAmount', async (amt) => {
          this.qrUrl = await window.__epcQr(amt);
        });
      }
    },
    get autoDisplayName() {
      const parts = this.donorName.trim().split(' ');
      if (!parts[0]) return '';
      return parts[0] + (parts[1] ? ' ' + parts[1][0] + '.' : '');
    },
    get feeInfo() {
      const base = this.finalAmount;
      if (base < 1) return { fee: '0.00' };
      const baseCents = Math.round(base * 100);
      let coveredCents;
      if (this.paymentMethod === 'sepa_debit') {
        coveredCents = baseCents + 35;
      } else if (this.paymentMethod === 'paypal') {
        coveredCents = Math.round((baseCents + 35 + 10) / (1 - 0.0249 - 0.002));
      } else {
        coveredCents = Math.round((baseCents + 25) / (1 - 0.015));
      }
      return { fee: ((coveredCents - baseCents) / 100).toFixed(2) };
    },

    async pay() {
      if (this.processing || this.finalAmount < 1) return;
      this.processing = true;
      this.error = '';

      try {
        const res = await fetch('/api/create-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            amount: this.finalAmount,
            donorName: this.donorName,
            showOnList: this.shareOnList,
            displayName: this.displayName || this.autoDisplayName,
            coverFees: this.coverFees,
            paymentMethod: this.paymentMethod,
            lang: lang,
          }),
        });

        const data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        } else {
          this.error = data.error || i18n.errorGeneric;
          this.processing = false;
        }
      } catch {
        this.error = i18n.errorConnection;
        this.processing = false;
      }
    }
  }));
});
</script>

<script>
import QRCode from 'qrcode';
window.__epcQr = (amount: number) => {
  const amountStr = amount > 0 ? `EUR${Number(amount).toFixed(2)}` : 'EUR';
  const payload = [
    'BCD', '002', '1', 'SCT',
    'COLSDE33XXX',
    'Worldculture Empowerment e.V.',
    'DE63370501981958894881',
    amountStr, '', 'Velid',
  ].join('\n');
  return QRCode.toDataURL(payload, {
    margin: 1,
    errorCorrectionLevel: 'M',
    color: { dark: '#2c2a26', light: '#f8f7f4' },
    width: 176,
  });
};
</script>

<div
    x-data="donationSheet"
    @open-stripe.window="const s = $refs.sheet; if (s) { s.style.transition = ''; s.style.transform = ''; } open = true; processing = false; error = ''; donorName = ''; customAmount = ''; amount = 25; shareOnList = true; displayName = ''; coverFees = false; paymentMethod = 'sepa_debit';"
    class="fixed inset-0 z-50 flex flex-col justify-end pointer-events-none"
>
    <!-- Backdrop -->
    <div
        x-show="open"
        x-cloak
        x-transition:enter="transition-opacity ease-out duration-300"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition-opacity ease-in duration-250"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        class="absolute inset-0 bg-black/40 pointer-events-auto"
        @click="open = false"
    >
    </div>

    <!-- Sheet panel -->
    <div
        x-show="open"
        x-cloak
        x-ref="sheet"
        x-transition:enter="transition-transform ease-[cubic-bezier(0.32,0.72,0,1)] duration-500"
        x-transition:enter-start="translate-y-full"
        x-transition:enter-end="translate-y-0"
        x-transition:leave="transition-transform ease-in duration-300"
        x-transition:leave-start="translate-y-0"
        x-transition:leave-end="translate-y-full"
        class="relative flex flex-col bg-white rounded-t-[20px] max-h-[92vh] max-w-lg mx-auto w-full shadow-[0_-8px_40px_rgba(0,0,0,0.12)] pointer-events-auto"
        style="will-change: transform;"
    >
        <!-- Handle bar (touch only) -->
        <div
            class="md:hidden flex justify-center pt-3 pb-2 flex-shrink-0 touch-none select-none"
            @touchstart="dragStart($event)"
            @touchmove.prevent="dragMove($event)"
            @touchend="dragEnd()"
        >
            <div class="w-10 h-1 bg-[#e0ddd8] rounded-full"></div>
        </div>

        <!-- Scrollable inner content -->
        <div class="overflow-y-auto overscroll-contain flex-1">
            <!-- Header -->
            <div class="flex items-start justify-between px-5 pt-3 pb-4">
                <div class="flex items-center gap-3">
                    <img
                        src="/dream-of-hearing/images/logo/wce-logo.webp"
                        alt="WCE Logo"
                        class="w-10 h-10 rounded-full object-cover flex-shrink-0"
                    />
                    <div>
                        <p
                            class="text-[12px] text-text-light font-semibold uppercase tracking-[0.8px]"
                        >
                            {t('stripe.donateTo')}
                        </p>
                        <p
                            class="text-[15px] font-semibold text-[#2c2a26] mt-0.5 leading-snug"
                        >
                            {campaignName}
                        </p>
                    </div>
                </div>
                <button
                    @click="open = false"
                    class="w-8 h-8 rounded-full bg-[#f5f4f0] flex items-center justify-center text-text-mid hover:bg-accent-soft transition-colors mt-0.5 flex-shrink-0"
                    aria-label="Close"
                >
                    <svg width="11" height="11" viewBox="0 0 11 11" fill="none">
                        <path
                            d="M1 1L10 10M10 1L1 10"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"></path>
                    </svg>
                </button>
            </div>

            <!-- Amount selector -->
            <div class="px-5 pb-4">
                <p
                    class="text-[11px] font-semibold text-text-light uppercase tracking-[0.8px] mb-2"
                >
                    {t('stripe.amount')}
                </p>
                <div class="grid grid-cols-4 gap-2 mb-2.5">
                    <template x-for="a in amounts" :key="a">
                        <button
                            @click="amount = a; customAmount = ''"
                            :class="amount === a && !customAmount ? 'bg-[#2c2a26] text-white border-[#2c2a26]' : 'bg-white text-[#2c2a26] border-[#d4d0c8] hover:border-[#a8a298]'"
                            class="py-2.5 rounded-[8px] border text-[13px] font-semibold transition-all"
                            x-text="'€' + a"></button>
                    </template>
                </div>
                <div class="relative">
                    <span
                        class="absolute left-3 top-1/2 -translate-y-1/2 text-[13px] text-text-light pointer-events-none"
                        >€</span
                    >
                    <input
                        type="number"
                        placeholder={t('stripe.customAmount')}
                        x-model="customAmount"
                        @input="if (customAmount) amount = 0"
                        class="w-full pl-7 pr-4 py-2.5 rounded-[8px] border border-[#d4d0c8] text-[16px] text-[#2c2a26] placeholder:text-[#c4c0b8] focus:outline-none focus:border-[#2c2a26] transition-colors bg-transparent"
                    />
                </div>
            </div>

            <div class="h-px bg-[#f0ede8] mx-5 mb-4"></div>

            <!-- Payment method selector -->
            <div class="px-5 pb-4">
                <p
                    class="text-[11px] font-semibold text-text-light uppercase tracking-[0.8px] mb-2"
                >
                    {t('stripe.paymentMethod')}
                </p>
                <div class="grid grid-cols-4 gap-2">
                    <!-- Credit Card -->
                    <button
                        @click="paymentMethod = 'card'"
                        :class="paymentMethod === 'card' ? 'bg-[#2c2a26] text-white border-[#2c2a26]' : 'bg-white text-text-mid border-[#d4d0c8] hover:border-[#a8a298]'"
                        class="py-3 px-2 rounded-[10px] border text-[11px] font-semibold transition-all flex flex-col items-center gap-1.5"
                    >
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <rect x="2" y="5" width="20" height="14" rx="2.5"
                            ></rect>
                            <path d="M2 10h20"></path>
                            <path d="M6 15h2M11 15h4" stroke-width="1.5"></path>
                        </svg>
                        <span>{t('stripe.creditCard')}</span>
                    </button>

                    <!-- SEPA Direct Debit -->
                    <button
                        @click="paymentMethod = 'sepa_debit'"
                        :class="paymentMethod === 'sepa_debit' ? 'bg-[#2c2a26] text-white border-[#2c2a26]' : 'bg-white text-text-mid border-[#d4d0c8] hover:border-[#a8a298]'"
                        class="py-3 px-2 rounded-[10px] border text-[11px] font-semibold transition-all flex flex-col items-center gap-1.5 relative"
                    >
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path d="M3 21h18"></path>
                            <path d="M3 10h18"></path>
                            <path d="M5 6l7-3 7 3"></path>
                            <path d="M5 10v11M9 10v11M15 10v11M19 10v11"></path>
                        </svg>
                        <span>{t('stripe.directDebit')}</span>
                    </button>

                    <!-- PayPal -->
                    <button
                        @click="paymentMethod = 'paypal'"
                        :class="paymentMethod === 'paypal' ? 'bg-[#2c2a26] text-white border-[#2c2a26]' : 'bg-white text-text-mid border-[#d4d0c8] hover:border-[#a8a298]'"
                        class="py-3 px-2 rounded-[10px] border text-[11px] font-semibold transition-all flex flex-col items-center gap-1.5"
                    >
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            aria-label="PayPal"
                        >
                            <path
                                d="M19.554 9.488c.121.76.07 1.607-.195 2.496-.812 2.814-3.18 3.787-6.32 3.787h-.408a.795.795 0 0 0-.785.672l-.59 3.73-.166 1.053a.419.419 0 0 1-.413.358H8.401a.35.35 0 0 1-.345-.404l.68-4.31.042-.198a.795.795 0 0 1 .785-.672h.408c2.45 0 4.37-.695 4.932-2.706.234-.832.113-1.527-.2-2.013.585.248 1 .675 1.202 1.307z"
                                opacity=".65"></path>
                            <path
                                d="M18.352 8.18a5.67 5.67 0 0 0-.422-.094 10.195 10.195 0 0 0-1.624-.12H11.94a.795.795 0 0 0-.786.672L10.11 15.6l-.042.265a.795.795 0 0 1 .785-.672h.408c3.14 0 5.508-.973 6.32-3.787.216-.888.266-1.736.146-2.496-.137-.085-.282-.163-.435-.233a5.28 5.28 0 0 0-.94-.497z"
                                opacity=".85"></path>
                            <path
                                d="M10.703 8.638a.795.795 0 0 1 .786-.672h4.366c.517 0 1 .033 1.445.103.127.02.25.043.37.068l.208.046c.153.07.298.148.435.233.158-.997.006-1.676-.546-2.29-.605-.67-1.696-.958-3.092-.958H9.818a.795.795 0 0 0-.786.672L7.29 17.26a.476.476 0 0 0 .47.55H10.6l.762-4.827.341-2.344z"
                            ></path>
                        </svg>
                        <span>{t('stripe.paypal')}</span>
                    </button>

                    <!-- Bank Transfer -->
                    <button
                        @click="paymentMethod = 'bank'"
                        :class="paymentMethod === 'bank' ? 'bg-[#2c2a26] text-white border-[#2c2a26]' : 'bg-white text-text-mid border-[#d4d0c8] hover:border-[#a8a298]'"
                        class="py-3 px-2 rounded-[10px] border text-[11px] font-semibold transition-all flex flex-col items-center gap-1.5 relative"
                    >
                        <span
                            class="bg-[#e8f5e9] text-[#2e7d32] absolute -top-2 left-1/2 -translate-x-1/2 text-[9px] font-bold px-1.5 py-0.5 rounded-full whitespace-nowrap transition-colors"
                        >{t('bank.noFeesBadge')}</span>
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                            <polyline points="9 22 9 12 15 12 15 22"></polyline>
                        </svg>
                        <span>{t('stripe.bankTransfer')}</span>
                    </button>
                </div>
            </div>

            <div class="h-px bg-[#f0ede8] mx-5 mb-4" x-show="paymentMethod !== 'bank'"></div>

            <!-- Donor listing section -->
            <div class="px-5 pb-4" x-show="paymentMethod !== 'bank'">
                <p
                    class="text-[11px] font-semibold text-text-light uppercase tracking-[0.8px] mb-3"
                >
                    {t('stripe.donorList')}
                </p>

                <input
                    type="text"
                    placeholder={t('stripe.yourName')}
                    x-model="donorName"
                    class="w-full px-3 py-2.5 rounded-[10px] border border-[#d4d0c8] text-[16px] text-[#2c2a26] placeholder:text-[#c4c0b8] focus:outline-none focus:border-[#2c2a26] transition-colors bg-transparent mb-3"
                />

                <!-- Show on list checkbox -->
                <label
                    class="flex items-start gap-3 cursor-pointer mb-3 select-none"
                >
                    <div class="relative flex-shrink-0 mt-0.5">
                        <input
                            type="checkbox"
                            x-model="shareOnList"
                            class="sr-only"
                        />
                        <div
                            :class="shareOnList ? 'bg-[#2c2a26] border-[#2c2a26]' : 'bg-white border-[#d4d0c8] hover:border-[#a8a298]'"
                            class="w-5 h-5 rounded-[5px] border-2 transition-all flex items-center justify-center"
                        >
                            <svg
                                x-show="shareOnList"
                                class="w-3 h-3 text-white flex-shrink-0"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="3"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                    </div>
                    <div>
                        <p
                            class="text-[13px] font-medium text-[#2c2a26] leading-snug"
                        >
                            {t('stripe.showOnList')}
                        </p>
                        <p class="text-[12px] text-text-light mt-0.5">
                            {t('stripe.namePublic')}
                        </p>
                    </div>
                </label>

                <!-- Display name override -->
                <div
                    x-show="shareOnList"
                    x-transition:enter="transition ease-out duration-200"
                    x-transition:enter-start="opacity-0 -translate-y-1"
                    x-transition:enter-end="opacity-100 translate-y-0"
                    x-transition:leave="transition ease-in duration-150"
                    x-transition:leave-start="opacity-100 translate-y-0"
                    x-transition:leave-end="opacity-0 -translate-y-1"
                >
                    <input
                        type="text"
                        :placeholder="autoDisplayName || displayNamePlaceholder"
                        x-model="displayName"
                        class="w-full px-3 py-2.5 rounded-[10px] border border-[#d4d0c8] text-[16px] text-[#2c2a26] placeholder:text-[#c4c0b8] focus:outline-none focus:border-[#2c2a26] transition-colors"
                    />
                    <p class="text-[12px] text-text-light mt-1.5 ml-0.5">
                        {t('stripe.leaveEmpty')}
                        <span
                            class="text-text-mid font-medium"
                            x-text="autoDisplayName || yourNameFallback"></span>{t('stripe.toUse') ? ` ${t('stripe.toUse')}` : ''}
                    </p>
                </div>
            </div>

            <div class="h-px bg-[#f0ede8] mx-5 mb-4"></div>

            <!-- Cover fees checkbox -->
            <div class="px-5 pb-4" x-show="paymentMethod !== 'bank'">
                <label
                    class="flex items-start gap-3 cursor-pointer select-none"
                >
                    <div class="relative flex-shrink-0 mt-0.5">
                        <input
                            type="checkbox"
                            x-model="coverFees"
                            class="sr-only"
                        />
                        <div
                            :class="coverFees ? 'bg-[#2c2a26] border-[#2c2a26]' : 'bg-white border-[#d4d0c8] hover:border-[#a8a298]'"
                            class="w-5 h-5 rounded-[5px] border-2 transition-all flex items-center justify-center"
                        >
                            <svg
                                x-show="coverFees"
                                class="w-3 h-3 text-white flex-shrink-0"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="3"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                    </div>
                    <div>
                        <p
                            class="text-[13px] font-medium text-[#2c2a26] leading-snug flex items-center gap-2 flex-wrap"
                        >
                            {t('stripe.coverFees')}
                            <span
                                x-show="finalAmount >= 1"
                                x-text="'+€\u2009' + feeInfo.fee"
                                :class="coverFees ? 'bg-accent-soft text-[#2c2a26]' : 'bg-[#f0ede8] text-text-mid'"
                                class="text-[11px] font-semibold px-1.5 py-0.5 rounded-full transition-colors tabular-nums"
                            ></span>
                        </p>
                        <p class="text-[12px] text-text-light mt-0.5">
                            {t('stripe.feesExplainShort').split('–')[0].trim()}
                        </p>
                    </div>
                </label>
            </div>

            <!-- Fee info expandable -->
            <div class="px-5 pb-4 -mt-1" x-show="paymentMethod !== 'bank'">
                <button
                    @click="showFeeInfo = !showFeeInfo"
                    class="flex items-center gap-1 text-[12px] text-text-light hover:text-text-mid transition-colors select-none"
                >
                    <svg
                        width="12"
                        height="12"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        :class="showFeeInfo ? 'rotate-180' : ''"
                        class="transition-transform duration-200 flex-shrink-0"
                    >
                        <path d="M6 9l6 6 6-6"></path>
                    </svg>
                    <span
                        x-text={`showFeeInfo ? '${t('stripe.showLess')}' : '${t('stripe.learnMore')}'`}
                    ></span>
                </button>

                <div
                    x-show="showFeeInfo"
                    x-transition:enter="transition ease-out duration-200"
                    x-transition:enter-start="opacity-0 -translate-y-1"
                    x-transition:enter-end="opacity-100 translate-y-0"
                    x-transition:leave="transition ease-in duration-150"
                    x-transition:leave-start="opacity-100 translate-y-0"
                    x-transition:leave-end="opacity-0 -translate-y-1"
                    class="mt-3 bg-[#f8f7f4] rounded-[10px] p-3.5 text-[12px] text-text-mid space-y-2.5"
                >
                    <p class="text-[#2c2a26] font-medium text-[12px]">
                        {t('stripe.whyFees')}
                    </p>
                    {t('stripe.feesExplain').split('\n\n').map((para) => (
                        <p class="leading-relaxed">{para}</p>
                    ))}
                    <div class="h-px bg-[#ece9e3]"></div>
                    <p class="text-[#2c2a26] font-medium text-[12px]">
                        {t('stripe.feesByMethod')}
                    </p>
                    <div class="space-y-2">
                        <div class="flex items-center justify-between">
                            <span class="flex items-center gap-1.5">
                                <svg
                                    width="13"
                                    height="13"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <rect
                                        x="2"
                                        y="5"
                                        width="20"
                                        height="14"
                                        rx="2.5"></rect>
                                    <path d="M2 10h20"></path>
                                </svg>
                                {t('stripe.creditCard')}
                            </span>
                            <span
                                class="tabular-nums font-medium text-[#2c2a26]"
                                >1,5 % + 0,25 €</span
                            >
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="flex items-center gap-1.5">
                                <svg
                                    width="13"
                                    height="13"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <path
                                        d="M3 21h18M3 10h18M5 6l7-3 7 3M5 10v11M9 10v11M15 10v11M19 10v11"
                                    ></path>
                                </svg>
                                {t('stripe.sepa')}
                            </span>
                            <span
                                class="tabular-nums font-medium text-[#2c2a26]"
                                >0,35 €</span
                            >
                        </div>
                        <div class="flex items-start justify-between">
                            <span class="flex items-start gap-1.5">
                                <svg
                                    width="13"
                                    height="13"
                                    viewBox="0 0 24 24"
                                    fill="currentColor"
                                >
                                    <path
                                        d="M10.703 8.638a.795.795 0 0 1 .786-.672h4.366c.517 0 1 .033 1.445.103.127.02.25.043.37.068l.208.046c.153.07.298.148.435.233.158-.997.006-1.676-.546-2.29-.605-.67-1.696-.958-3.092-.958H9.818a.795.795 0 0 0-.786.672L7.29 17.26a.476.476 0 0 0 .47.55H10.6l.762-4.827.341-2.344z"
                                        opacity=".6"></path>
                                    <path
                                        d="M19.554 9.488c.121.76.07 1.607-.195 2.496-.812 2.814-3.18 3.787-6.32 3.787h-.408a.795.795 0 0 0-.785.672l-.756 4.783a.419.419 0 0 1-.413.358H8.401a.35.35 0 0 1-.345-.404l.68-4.31.042-.198a.795.795 0 0 1 .785-.672h.408c2.45 0 4.37-.695 4.932-2.706.234-.832.113-1.527-.2-2.013.787.335 1.202.675 1.202 1.307.153.07.298.148.435.233.516-.233.994-.39 1.214-.066z"
                                    ></path>
                                </svg>
                                {t('stripe.paypal')}
                            </span>
                            <span
                                class="tabular-nums font-medium text-[#2c2a26] text-right"
                                >2,49 % + 0,35 €<br />zzgl. Stripe</span
                            >
                        </div>
                    </div>
                    <div class="h-px bg-[#ece9e3]"></div>
                    <p class="leading-relaxed" set:html={t('stripe.feeExample')} />
                </div>
            </div>

            <!-- Error message (Stripe only) -->
            <div x-show="error && paymentMethod !== 'bank'" x-cloak class="px-5 pb-3">
                <p
                    class="text-[12px] text-red-500 bg-red-50 rounded-[8px] px-3 py-2"
                    x-text="error"
                >
                </p>
            </div>

            <!-- Pay button (Stripe methods) -->
            <div class="px-5 pb-7" x-show="paymentMethod !== 'bank'">
                <button
                    @click="pay()"
                    :disabled="processing || finalAmount < 1"
                    :class="processing ? 'opacity-75 cursor-not-allowed' : 'hover:opacity-90 active:scale-[0.99]'"
                    class="w-full py-3.5 rounded-[10px] bg-[#2c2a26] text-white text-[14px] font-semibold transition-all relative overflow-hidden"
                >
                    <span
                        x-show="!processing"
                        x-text="(coverFees && finalAmount >= 1
                        ? (finalAmount + parseFloat(feeInfo.fee)).toFixed(2).replace(/\.00$/, '')
                        : finalAmount) + ' ' + donateButtonSuffix"
                    ></span>
                    <span
                        x-show="processing"
                        class="flex items-center justify-center gap-2"
                    >
                        <svg
                            class="animate-spin h-4 w-4 text-white"
                            fill="none"
                            viewBox="0 0 24 24"
                        >
                            <circle
                                class="opacity-25"
                                cx="12"
                                cy="12"
                                r="10"
                                stroke="currentColor"
                                stroke-width="4"></circle>
                            <path
                                class="opacity-75"
                                fill="currentColor"
                                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                            ></path>
                        </svg>
                        {t('stripe.redirecting')}
                    </span>
                </button>

                <!-- Powered by Stripe -->
                <div class="flex items-center justify-center gap-1.5 mt-3.5">
                    <svg
                        width="11"
                        height="11"
                        viewBox="0 0 24 24"
                        fill="#b0acaa"
                    >
                        <path
                            d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"
                        ></path>
                    </svg>
                    <span class="text-[11px] text-[#c4c0b8]"
                        >{t('stripe.securePayment')}</span
                    >
                    <svg
                        viewBox="0 0 60 25"
                        xmlns="http://www.w3.org/2000/svg"
                        width="40"
                        class="UserLogo variant--"
                        ><title>Stripe logo</title><path
                            fill="var(--userLogoColor, #0A2540)"
                            d="M59.64 14.28h-8.06c.19 1.93 1.6 2.55 3.2 2.55 1.64 0 2.96-.37 4.05-.95v3.32a8.33 8.33 0 0 1-4.56 1.1c-4.01 0-6.83-2.5-6.83-7.48 0-4.19 2.39-7.52 6.3-7.52 3.92 0 5.96 3.28 5.96 7.5 0 .4-.04 1.26-.06 1.48zm-5.92-5.62c-1.03 0-2.17.73-2.17 2.58h4.25c0-1.85-1.07-2.58-2.08-2.58zM40.95 20.3c-1.44 0-2.32-.6-2.9-1.04l-.02 4.63-4.12.87V5.57h3.76l.08 1.02a4.7 4.7 0 0 1 3.23-1.29c2.9 0 5.62 2.6 5.62 7.4 0 5.23-2.7 7.6-5.65 7.6zM40 8.95c-.95 0-1.54.34-1.97.81l.02 6.12c.4.44.98.78 1.95.78 1.52 0 2.54-1.65 2.54-3.87 0-2.15-1.04-3.84-2.54-3.84zM28.24 5.57h4.13v14.44h-4.13V5.57zm0-4.7L32.37 0v3.36l-4.13.88V.88zm-4.32 9.35v9.79H19.8V5.57h3.7l.12 1.22c1-1.77 3.07-1.41 3.62-1.22v3.79c-.52-.17-2.29-.43-3.32.86zm-8.55 4.72c0 2.43 2.6 1.68 3.12 1.46v3.36c-.55.3-1.54.54-2.89.54a4.15 4.15 0 0 1-4.27-4.24l.01-13.17 4.02-.86v3.54h3.14V9.1h-3.13v5.85zm-4.91.7c0 2.97-2.31 4.66-5.73 4.66a11.2 11.2 0 0 1-4.46-.93v-3.93c1.38.75 3.1 1.31 4.46 1.31.92 0 1.53-.24 1.53-1C6.26 13.77 0 14.51 0 9.95 0 7.04 2.28 5.3 5.62 5.3c1.36 0 2.72.2 4.09.75v3.88a9.23 9.23 0 0 0-4.1-1.06c-.86 0-1.44.25-1.44.9 0 1.85 6.29.97 6.29 5.88z"
                            fill-rule="evenodd"></path></svg
                    >
                </div>
            </div>
            <!-- Bank transfer details (shown when bank tile selected) -->
            <div class="px-5 pb-7" x-show="paymentMethod === 'bank'" x-data="{ ibanCopied: false }">
                <div class="bg-[#f8f7f4] rounded-[12px] p-4">
                    <div class="flex items-start gap-4">
                        <!-- Text details -->
                        <div class="flex-1 space-y-3">
                            <div class="space-y-2 text-[13px]">
                                <div class="flex items-end justify-between gap-2">
                                    <div>
                                        <span class="text-[11px] text-text-light uppercase tracking-[0.6px] font-semibold block mb-0.5">{t('bank.iban')}</span>
                                        <span class="font-mono font-semibold text-[#2c2a26] tracking-wide">DE63 3705 0198 1958 8948 81</span>
                                    </div>
                                    <button
                                        @click="navigator.clipboard.writeText('DE63370501981958894881').then(() => { ibanCopied = true; setTimeout(() => ibanCopied = false, 2000) })"
                                        class="flex-shrink-0 text-[11px] font-semibold px-2.5 py-1 rounded-md border border-[#d4d0c8] text-text-mid hover:border-[#a8a298] hover:text-text-mid transition-all"
                                        x-text={`ibanCopied ? '${t('bank.copied')}' : '${t('bank.copy')}'`}
                                    ></button>
                                </div>
                                <div>
                                    <span class="text-[11px] text-text-light uppercase tracking-[0.6px] font-semibold block mb-0.5">{t('bank.bic')}</span>
                                    <span class="font-mono font-semibold text-[#2c2a26] tracking-wide">COLSDE33XXX</span>
                                </div>
                                <div>
                                    <span class="text-[11px] text-text-light uppercase tracking-[0.6px] font-semibold block mb-0.5">{t('bank.reference')}</span>
                                    <span class="font-semibold text-[#2c2a26]">Velid</span>
                                </div>
                            </div>
                            <p class="text-[11px] text-text-light leading-relaxed border-t border-[#ece9e3] pt-3">
                                {t('bank.donorListHint')}
                            </p>
                        </div>
                        <!-- EPC QR code — desktop only -->
                        <div class="hidden md:flex flex-col items-center gap-1.5 flex-shrink-0">
                            <img :src="qrUrl" class="w-[88px] h-[88px] rounded-[8px]" alt="EPC QR Code" />
                            <span class="text-[10px] text-[#b0acaa] font-medium text-center">{t('bank.qrScan')}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div><!-- end scrollable inner -->
    </div><!-- end sheet panel -->
</div>
