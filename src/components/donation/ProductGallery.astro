---
interface Props {
    basePath: string;
}

const { basePath } = Astro.props;
const orgUrl = import.meta.env.PUBLIC_ORG_URL || 'https://worldculture-empowerment.international';
const externalVideoBase =
    `${orgUrl}/website-template/images/projects/dream-of-hearing`;

const items = [
    {
        type: "image" as const,
        src: `${basePath}/images/dream-of-hearing-1.webp`,
    },
    {
        type: "image" as const,
        src: `${basePath}/images/dream-of-hearing-2.webp`,
    },
    {
        type: "image" as const,
        src: `${basePath}/images/dream-of-hearing-3.webp`,
    },
    { type: "video" as const, src: `${externalVideoBase}/video1.mp4`, aspectRatio: "3/4" },
    { type: "video" as const, src: `${externalVideoBase}/video2.mp4`, aspectRatio: "3/4" },
    { type: "video" as const, src: `${externalVideoBase}/video3.mp4`, aspectRatio: "3/4" },
];
---

<div class="gallery" data-gallery>
    <div class="gallery-track" data-gallery-track>
        {
            items.map((item, i) => (
                <div class="gallery-slide" data-index={i}>
                    {item.type === "image" ? (
                        <img
                            src={item.src}
                            alt={`Bild ${i + 1}`}
                            class="gallery-media"
                            loading={i === 0 ? "eager" : "lazy"}
                        />
                    ) : (
                        <div style={`position: relative; width: 100%; aspect-ratio: ${item.aspectRatio};`}>
                            <video
                                src={item.src}
                                class="gallery-media"
                                playsinline
                                loop
                                preload="none"
                                data-gallery-video
                            />
                            <div class="video-loader" aria-hidden="true" hidden>
                                <div class="video-loader-spinner"></div>
                            </div>
                        </div>
                    )}
                </div>
            ))
        }
    </div>

    <button
        class="gallery-btn gallery-btn-prev"
        data-gallery-prev
        aria-label="Zurück"
    >
        <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
    </button>
    <button
        class="gallery-btn gallery-btn-next"
        data-gallery-next
        aria-label="Weiter"
    >
        <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
    </button>

    <div class="gallery-counter" data-gallery-counter>
        1/{items.length}
    </div>

    <button
        class="gallery-mute"
        data-gallery-mute
        aria-label="Ton deaktivieren"
        hidden
    >
        <!-- muted icon (shown when muted) -->
        <svg
            data-mute-icon="muted"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
            <line x1="23" y1="9" x2="17" y2="15"></line>
            <line x1="17" y1="9" x2="23" y2="15"></line>
        </svg>
        <!-- unmuted icon (shown when unmuted) -->
        <svg
            data-mute-icon="unmuted"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            style="display:none"
        >
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
            <path d="M19.07 4.93a10 10 0 010 14.14"></path>
            <path d="M15.54 8.46a5 5 0 010 7.07"></path>
        </svg>
    </button>

    <div class="gallery-dots flex items-center">
        {
            items.map((item, i) => (
                <button
                    class:list={[
                        "gallery-dot",
                        { active: i === 0 },
                        { "gallery-dot-video": item.type === "video" },
                    ]}
                    data-gallery-dot={i}
                    aria-label={
                        item.type === "video"
                            ? `Zu Video ${i + 1}`
                            : `Zu Bild ${i + 1}`
                    }
                >
                    {item.type === "video" && (
                        <svg
                            viewBox="0 0 10 10"
                            fill="currentColor"
                            aria-hidden="true"
                        >
                            <polygon points="2,1 9,5 2,9" />
                        </svg>
                    )}
                </button>
            ))
        }
    </div>
</div>

<style>
    .gallery {
        position: relative;
        overflow: hidden;
        transition: height 0.3s ease;
    }

    .gallery-track {
        display: flex;
        align-items: flex-start;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .gallery-track::-webkit-scrollbar {
        display: none;
    }

    .gallery-slide {
        flex: 0 0 100%;
        scroll-snap-align: center;
        position: relative;
    }

    .gallery-media {
        width: 100%;
        height: auto;
        display: block;
    }

    .gallery-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.9);
        color: #333;
        display: none;
        align-items: center;
        justify-content: center;
        border: none;
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
        z-index: 10;
        transition: opacity 0.15s;
    }

    .gallery-btn:hover {
        background: #fff;
    }

    .gallery-btn-prev {
        left: 10px;
    }

    .gallery-btn-next {
        right: 10px;
    }

    @media (min-width: 768px) {
        .gallery-btn {
            display: flex;
        }
        .gallery-btn[hidden] {
            display: none;
        }
    }

    @media (min-width: 1024px) {
        .gallery {
            border-radius: 12px;
            overflow: hidden;
        }
    }

    .gallery-counter {
        position: absolute;
        top: 12px;
        right: 12px;
        background: rgba(0, 0, 0, 0.6);
        color: #fff;
        font-size: 12px;
        font-weight: 500;
        padding: 3px 10px;
        border-radius: 100px;
        z-index: 10;
    }

    .gallery-mute {
        position: absolute;
        top: 12px;
        left: 12px;
        background: rgba(0, 0, 0, 0.6);
        color: #fff;
        font-size: 12px;
        font-weight: 500;
        padding: 3px 10px;
        border-radius: 100px;
        border: none;
        cursor: pointer;
        z-index: 10;
        display: flex;
        align-items: center;
        gap: 4px;
        line-height: 1;
    }

    .gallery-mute[hidden] {
        display: none;
    }

    .gallery-dots {
        position: absolute;
        bottom: 12px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 6px;
        z-index: 10;
    }

    .gallery-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        border: none;
        padding: 0;
        cursor: pointer;
        background: rgba(255, 255, 255, 0.45);
        transition:
            background 0.2s,
            color 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .gallery-dot.active {
        background: #fff;
    }

    .gallery-dot-video {
        width: 14px;
        height: 10px;
        border-radius: 3px;
        background: rgba(255, 255, 255, 0.45);
        color: rgba(255, 255, 255, 0.45);
    }

    .gallery-dot-video.active {
        background: rgba(255, 255, 255, 0.15);
        color: #fff;
    }

    .gallery-dot-video svg {
        width: 6px;
        height: 6px;
    }

    .video-placeholder {
        position: relative;
        width: 100%;
        background: linear-gradient(160deg, #1e1c1a 0%, #2a2724 100%);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .video-placeholder-icon {
        width: 64px;
        height: 64px;
    }

    .gallery-media[data-gallery-video] {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .video-loader {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.25);
        z-index: 5;
    }

    .video-loader[hidden] {
        display: none;
    }

    .video-loader-spinner {
        width: 36px;
        height: 36px;
        border: 3px solid rgba(255, 255, 255, 0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: gallery-spin 0.8s linear infinite;
    }

    @keyframes gallery-spin {
        to { transform: rotate(360deg); }
    }
</style>

<script>
    document
        .querySelectorAll<HTMLElement>("[data-gallery]")
        .forEach((gallery) => {
            const track = gallery.querySelector<HTMLElement>(
                "[data-gallery-track]",
            )!;
            const counter = gallery.querySelector<HTMLElement>(
                "[data-gallery-counter]",
            )!;
            const prevBtn = gallery.querySelector<HTMLButtonElement>(
                "[data-gallery-prev]",
            )!;
            const nextBtn = gallery.querySelector<HTMLButtonElement>(
                "[data-gallery-next]",
            )!;
            const muteBtn = gallery.querySelector<HTMLButtonElement>(
                "[data-gallery-mute]",
            )!;
            const mutedIcon = muteBtn.querySelector<SVGElement>(
                '[data-mute-icon="muted"]',
            )!;
            const unmutedIcon = muteBtn.querySelector<SVGElement>(
                '[data-mute-icon="unmuted"]',
            )!;
            const dots =
                gallery.querySelectorAll<HTMLButtonElement>(
                    "[data-gallery-dot]",
                );
            const total = track.children.length;
            let current = 0;
            let globalMuted = false;

            function currentVideo(): HTMLVideoElement | null {
                return (
                    (track.children[current] as HTMLElement)?.querySelector(
                        "video",
                    ) ?? null
                );
            }

            function syncHeight() {
                const slide = track.children[current] as HTMLElement;
                const media = slide?.querySelector("img, video") as
                    | HTMLImageElement
                    | HTMLVideoElement
                    | null;
                if (!media) return;
                const h = (media as HTMLElement).offsetHeight;
                if (h > 0) gallery.style.height = h + "px";
            }

            function applyMute(video: HTMLVideoElement) {
                video.muted = globalMuted;
            }

            function updateMuteButton(isVideo: boolean) {
                muteBtn.hidden = !isVideo;
                mutedIcon.style.display = globalMuted ? "" : "none";
                unmutedIcon.style.display = globalMuted ? "none" : "";
                muteBtn.setAttribute(
                    "aria-label",
                    globalMuted ? "Ton aktivieren" : "Ton deaktivieren",
                );
            }

            function updateUI(index: number) {
                if (
                    index === current &&
                    counter.textContent !== `${index + 1}/${total}`
                ) {
                    // First render
                } else if (index === current) {
                    return;
                }

                // Pause all videos, play current if video
                track.querySelectorAll("video").forEach((v) => v.pause());
                const currentSlide = track.children[index] as HTMLElement;
                const video = currentSlide?.querySelector("video");
                const loader = currentSlide?.querySelector<HTMLElement>(".video-loader");
                if (video) {
                    applyMute(video);
                    if (loader) {
                        if (video.readyState < 3) {
                            loader.hidden = false;
                            video.addEventListener("canplay", () => { loader.hidden = true; }, { once: true });
                        } else {
                            loader.hidden = true;
                        }
                    }
                    video.play().catch(() => {});
                }

                current = index;
                counter.textContent = `${current + 1}/${total}`;

                dots.forEach((dot, i) => {
                    dot.classList.toggle("active", i === current);
                });

                prevBtn.hidden = current === 0;
                nextBtn.hidden = current === total - 1;
                updateMuteButton(!!video);
                syncHeight();
            }

            function goTo(index: number) {
                track.scrollTo({
                    left: index * track.offsetWidth,
                    behavior: "smooth",
                });
            }

            muteBtn.addEventListener("click", () => {
                globalMuted = !globalMuted;
                const video = currentVideo();
                if (video) applyMute(video);
                updateMuteButton(true);
            });

            track.addEventListener(
                "scroll",
                () => {
                    const index = Math.round(
                        track.scrollLeft / track.offsetWidth,
                    );
                    updateUI(index);
                },
                { passive: true },
            );

            prevBtn.addEventListener("click", () => goTo(current - 1));
            nextBtn.addEventListener("click", () => goTo(current + 1));

            dots.forEach((dot) => {
                dot.addEventListener("click", () => {
                    goTo(Number(dot.dataset.galleryDot));
                });
            });

            // Tap to play/pause videos
            track.querySelectorAll("video").forEach((video) => {
                video.addEventListener("click", () => {
                    if (video.paused) video.play();
                    else video.pause();
                });
            });

            // Sync height when media loads (images & videos may not have dimensions yet)
            track.querySelectorAll("img").forEach((img) => {
                if (!img.complete)
                    img.addEventListener("load", syncHeight, { once: true });
            });
            track.querySelectorAll("video").forEach((video) => {
                video.addEventListener("loadedmetadata", syncHeight, { once: true });
            });

            // Sync height on window resize
            window.addEventListener("resize", syncHeight, { passive: true });

            // Initial state
            updateUI(0);
            syncHeight();

            // Prefetch first video after everything else has loaded
            window.addEventListener("load", () => {
                const firstVideo = track.querySelector<HTMLVideoElement>("video");
                if (firstVideo) {
                    firstVideo.preload = "auto";
                    firstVideo.load();
                }
            }, { once: true });
        });
</script>
