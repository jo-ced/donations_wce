---
import Label from '../Label.astro';

interface Props {
  intro: string;
  body: string;
  image: string;
}

const { intro, body, image } = Astro.props;
const paragraphs = body.split('\n').filter(p => p.trim());
---

<section class="px-5 py-4 border-b border-border" x-data="{ expanded: false }">
  <Label>Geschichte</Label>
  <p class="text-[15px] leading-relaxed text-text-mid m-0">{intro}</p>
  <div class="mt-3.5 rounded-[10px] overflow-hidden">
    <img src={image} alt="" class="block max-w-full" />
  </div>
  <div x-show="expanded" x-cloak x-transition class="mt-3.5 flex flex-col gap-3">
    {paragraphs.map((p) => (
      <p class="text-[15px] leading-relaxed text-text-mid m-0 whitespace-pre-line">{p}</p>
    ))}
  </div>
  <button
    @click="expanded = !expanded"
    class="mt-3 bg-transparent border-none p-0 text-sm font-semibold cursor-pointer flex items-center gap-1"
    style="color: #c2552d;"
  >
    <span x-text="expanded ? 'Weniger lesen' : 'Mehr lesen'">Mehr lesen</span>
    <svg
      width="12" height="12" viewBox="0 0 24 24" fill="none"
      stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
      class="transition-transform duration-200"
      :class="expanded ? 'rotate-180' : ''"
    >
      <polyline points="6 9 12 15 18 9" />
    </svg>
  </button>
</section>
