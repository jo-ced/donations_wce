---
import Label from '../Label.astro';
---

<section class="px-5 py-4 border-b border-border" x-data="{ expanded: false }">
  <Label>Geschichte</Label>
  <div class="relative">
    <div
      :class="expanded ? '' : 'max-h-44 overflow-hidden'"
      class="prose prose-sm max-w-none text-text-mid [&>p]:text-[15px] [&>p]:leading-relaxed [&>p]:m-0 [&>p+p]:mt-3"
    >
      <slot />
    </div>
    <div
      x-show="!expanded"
      class="absolute bottom-0 left-0 right-0 h-14 bg-gradient-to-t from-bg to-transparent pointer-events-none"
    ></div>
  </div>
  <button
    @click="expanded = !expanded"
    class="mt-3 bg-transparent border-none p-0 text-sm font-semibold cursor-pointer flex items-center gap-1"
    style="color: #c2552d;"
  >
    <span x-text="expanded ? 'Weniger lesen' : 'Mehr lesen'">Mehr lesen</span>
    <svg
      width="12" height="12" viewBox="0 0 24 24" fill="none"
      stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
      class="transition-transform duration-200"
      :class="expanded ? 'rotate-180' : ''"
    >
      <polyline points="6 9 12 15 18 9" />
    </svg>
  </button>
</section>
