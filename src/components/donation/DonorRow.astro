---
import Avatar from '../Avatar.astro';

interface Props {
  name: string;
  amount: number;
  currency: string;
}

const { name, amount, currency } = Astro.props;
---

<div class="flex items-center gap-2.5 py-2">
  <Avatar size={30} name={name} />
  <div class="flex-1">
    <span class="text-[11px] text-text">{name}</span>
  </div>
  <span class="text-xs font-semibold text-text-mid">{currency}{amount}</span>
</div>
