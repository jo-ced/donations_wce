---
interface Props {
  src: string;
  alt: string;
}

const { src, alt } = Astro.props;
---

<div class="h-[200px] bg-accent-soft flex items-center justify-center overflow-hidden">
  <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-light)" stroke-width="1.5">
    <rect x="3" y="3" width="18" height="18" rx="3" />
    <circle cx="8.5" cy="8.5" r="1.5" />
    <path d="M21 15l-5-5L5 21" />
  </svg>
</div>
