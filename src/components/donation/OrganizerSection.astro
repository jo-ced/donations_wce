---
import Label from '../Label.astro';

interface Props {
  name: string;
  location: string;
}

const { name, location } = Astro.props;
---

<section class="px-5 py-4 border-b border-border">
  <Label>Organisator</Label>
  <div class="flex items-center gap-3">
    <img
      src="/dream-of-hearing/images/logo/wce-logo.webp"
      alt={name}
      class="w-11 h-11 rounded-full object-cover shrink-0"
    />
    <div>
      <span class="text-sm font-semibold text-text block">{name}</span>
      <div class="mt-1.5 flex gap-1.5 items-center">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-light)" stroke-width="2">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
        <span class="text-[12px] text-text-light">{location}</span>
      </div>
    </div>
  </div>
</section>
