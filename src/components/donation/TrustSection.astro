---
import Label from "../Label.astro";

interface Props {
    items: { icon: string; label: string; description: string }[];
}

const { items } = Astro.props;

const icons: Record<string, string> = {
    fees: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <line x1="19" y1="5" x2="5" y2="19"/>
    <circle cx="6.5" cy="6.5" r="2.5"/>
    <circle cx="17.5" cy="17.5" r="2.5"/>
  </svg>`,
    impact: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="10"/>
    <circle cx="12" cy="12" r="6"/>
    <circle cx="12" cy="12" r="2"/>
  </svg>`,
    encrypted: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
    <path d="M7 11V7a5 5 0 0110 0v4"/>
  </svg>`,
};
---

<section class="px-5 py-4">
    <Label>Vertrauen</Label>
    <div class="flex gap-2.5">
        {
            items.map((item) => (
                <div class="flex-1 py-3.5 px-2 bg-surface rounded-[10px] border border-border text-center">
                    <div
                        class="w-8 h-8 rounded-full bg-accent-soft mx-auto mb-2 flex items-center justify-center text-accent"
                        set:html={icons[item.icon] ?? icons.encrypted}
                    />
                    <span class="text-[10px] font-semibold text-text-mid block leading-tight">
                        {item.label}
                    </span>
                    <span class="text-[9px] text-text-light block mt-0.5 leading-tight">
                        {item.description}
                    </span>
                </div>
            ))
        }
    </div>
</section>
