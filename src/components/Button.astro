---
interface Props {
  primary?: boolean;
  flex?: boolean;
}

const { primary = false, flex = false } = Astro.props;
---

<button
  class:list={[
    'px-5 py-3 rounded-[10px] text-[13px] font-semibold tracking-[0.3px] cursor-pointer',
    flex && 'flex-1',
    primary
      ? 'border-none bg-accent text-white'
      : 'border-[1.5px] border-border-dark bg-transparent text-text',
  ]}
>
  <slot />
</button>
