---
interface Props {
  size?: number;
  name?: string;
}

const { size = 36, name = '' } = Astro.props;

const initials = name
  .split(/\s+/)
  .filter(Boolean)
  .map((w) => w[0].toUpperCase())
  .slice(0, 2)
  .join('');

const fontSize = Math.round(size * 0.38);
---

<div
  style={`width: ${size}px; height: ${size}px; background: linear-gradient(135deg, #c2552d, #e0845e); font-size: ${fontSize}px;`}
  class="rounded-full shrink-0 flex items-center justify-center text-white font-semibold leading-none select-none"
>
  {initials}
</div>
