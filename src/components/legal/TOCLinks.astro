---
interface Props {
  count: number;
}

const { count } = Astro.props;
const items = Array.from({ length: count }, (_, i) => i);
const widths = [100, 130, 160];
---

<div class="mt-3 mb-2 p-3 bg-surface rounded-lg border border-border">
  <span class="text-[10px] font-semibold text-text-mid mb-2 block">Contents</span>
  <div class="flex flex-col gap-2">
    {items.map((i) => (
      <div class="flex items-center gap-2">
        <span class="text-[10px] text-text-light font-semibold w-4">{i + 1}.</span>
        <div style={`width: ${widths[i % 3]}px; height: 8px; border-radius: 4px; background: var(--color-accent-soft);`}></div>
      </div>
    ))}
  </div>
</div>
