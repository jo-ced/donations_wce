---
import BaseLayout from '../layouts/BaseLayout.astro';
import Label from '../components/Label.astro';
import TextBlock from '../components/TextBlock.astro';
import PageTabs from '../components/legal/PageTabs.astro';
import DataTable from '../components/legal/DataTable.astro';
import CookieToggles from '../components/legal/CookieToggles.astro';
import ContactFooter from '../components/legal/ContactFooter.astro';

const pages = {
  AGB: {
    updated: 'Zuletzt aktualisiert: Jan 2026',
    sections: [
      { heading: 160, lines: [95, 88, 78, 92, 65] },
      { heading: 120, lines: [90, 85, 70, 93, 88, 60] },
      { heading: 180, lines: [88, 92, 75, 80] },
      { heading: 140, lines: [92, 86, 70, 95, 55] },
      { heading: 100, lines: [85, 90, 78, 88, 72, 65] },
      { heading: 150, lines: [90, 82, 68] },
    ],
  },
  Datenschutz: {
    updated: 'Zuletzt aktualisiert: Dez 2025',
    sections: [
      { heading: 200, lines: [93, 87, 75, 90, 82] },
      { heading: 170, lines: [88, 92, 68, 85, 90, 74] },
      { heading: 130, lines: [90, 80, 95, 72] },
      { heading: 190, lines: [86, 92, 78, 88] },
      { heading: 110, lines: [92, 85, 70, 90, 65] },
      { heading: 160, lines: [88, 75, 93, 80, 70] },
    ],
  },
  Cookies: {
    updated: 'Zuletzt aktualisiert: Nov 2025',
    sections: [
      { heading: 170, lines: [90, 85, 78, 92] },
      { heading: 140, lines: [88, 80, 95, 72, 86] },
      { heading: 120, lines: [92, 88, 65] },
    ],
  },
  Barrierefreiheit: {
    updated: 'Zuletzt aktualisiert: Okt 2025',
    sections: [
      { heading: 190, lines: [92, 86, 78, 90, 70] },
      { heading: 150, lines: [88, 94, 72, 85] },
      { heading: 130, lines: [90, 82, 76, 88, 65] },
      { heading: 170, lines: [85, 92, 70] },
    ],
  },
};

const tocWidths = [100, 130, 160];
---

<BaseLayout title="Rechtliches">
  <div class="min-h-screen bg-bg text-text" x-data="{ activePage: 'AGB' }">
    <div class="max-w-lg mx-auto">
      <!-- Tabs -->
      <PageTabs />

      <!-- Content area -->
      <div class="px-5 pt-5 pb-10">
        {Object.entries(pages).map(([key, page]) => (
          <div x-show={`activePage === '${key}'`} x-cloak>
            <!-- Header -->
            <Label>Rechtliches</Label>
            <div class="w-[85%] h-5 rounded bg-border-dark"></div>
            <div class="mt-2 text-[10px] text-text-light">{page.updated}</div>

            <!-- TOC -->
            <div class="mt-3 mb-2 p-3 bg-surface rounded-lg border border-border">
              <span class="text-[10px] font-semibold text-text-mid mb-2 block">Inhalt</span>
              <div class="flex flex-col gap-2">
                {page.sections.map((_, i) => (
                  <div class="flex items-center gap-2">
                    <span class="text-[10px] text-text-light font-semibold w-4">{i + 1}.</span>
                    <div style={`width: ${tocWidths[i % 3]}px; height: 8px; border-radius: 4px; background: var(--color-accent-soft);`}></div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Sections -->
            {page.sections.map((s, i) => (
              <div>
                <!-- Section heading -->
                <div class="mt-[22px] mb-2.5">
                  <div style={`width: ${s.heading}px; height: 13px; border-radius: 4px; background: var(--color-border-dark);`}></div>
                </div>
                <!-- Text lines -->
                <TextBlock lines={s.lines} />
                <!-- Extra content for specific pages -->
                {key === 'Datenschutz' && i === 1 && <DataTable />}
                {key === 'Cookies' && i === 1 && <CookieToggles />}
              </div>
            ))}

            <!-- Contact footer -->
            <ContactFooter />

            <!-- Footer links -->
            <div class="mt-5 text-center">
              <div class="w-[100px] h-2 rounded bg-accent-soft mx-auto"></div>
              <div class="mt-1.5 flex justify-center gap-3">
                {['AGB', 'Datenschutz', 'Cookies', 'Barrierefreiheit'].map((t) => (
                  <span
                    @click={`activePage = '${t}'`}
                    :class={`activePage === '${t}' ? 'font-semibold text-text' : 'font-normal text-text-light'`}
                    class="text-[9px] cursor-pointer"
                  >
                    {t}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
