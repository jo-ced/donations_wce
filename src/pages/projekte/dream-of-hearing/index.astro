---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import NavBar from "../../../components/donation/NavBar.astro";
import ProductGallery from "../../../components/donation/ProductGallery.astro";
import CampaignTitle from "../../../components/donation/CampaignTitle.astro";
import ProgressSection from "../../../components/donation/ProgressSection.astro";
import Story from "../../../components/donation/Story.astro";
import DonationsList from "../../../components/donation/DonationsList.astro";
import OrganizerSection from "../../../components/donation/OrganizerSection.astro";
import FundingSection from "../../../components/donation/FundingSection.astro";
import TrustSection from "../../../components/donation/TrustSection.astro";
import StickyBottom from "../../../components/donation/StickyBottom.astro";
import FooterLinks from "../../../components/FooterLinks.astro";
import StripeSheet from "../../../components/donation/StripeSheet.astro";
import ShareDialog from "../../../components/donation/ShareDialog.astro";
import { CAMPAIGN_GOAL, getCurrencySymbol } from "../../../data/donations";

const allProjects = await getCollection("projects");
const project = allProjects.find(p => p.id === "velids-traum-vom-hoeren");
if (!project) throw new Error("Project not found");
const { data } = project;
const { Content } = await render(project);

const currency = getCurrencySymbol("eur");
const goal = CAMPAIGN_GOAL / 100;
---

<BaseLayout title={data.title}>
    <div class="min-h-screen bg-bg text-text pb-40 lg:pb-0">
        <!-- Navbar -->
        <div class="max-w-5xl mx-auto">
            <NavBar siteName={data.nav.siteName} />
        </div>

        <!-- Campaign title: above grid on desktop -->
        <div class="block max-w-5xl mx-auto lg:px-6 lg:pt-6">
            <CampaignTitle
                title={data.title}
                subtitle={data.subtitle}
                organizerName={data.organizer.name}
                organizerRole={data.organizer.role}
            />
        </div>

        <!-- Main content: single column on mobile, two-column on desktop -->
        <div
            class="max-w-5xl mx-auto lg:grid lg:grid-cols-[1fr_360px] lg:gap-8 lg:px-6 lg:pt-4 lg:pb-10 lg:items-start"
        >
            <!-- Left column: gallery + story + donations -->
            <div>
                <ProductGallery basePath="/dream-of-hearing" />
                <Story intro={data.storyIntro}>
                    <Content />
                </Story>
                <DonationsList
                    currency={currency}
                    disclaimer={data.donorDisclaimer}
                />
            </div>

            <!-- Right column: sticky sidebar -->
            <div
                class="lg:sticky lg:top-6 lg:border lg:border-border lg:rounded-xl lg:overflow-hidden lg:shadow-sm"
            >
                <ProgressSection
                    goal={goal}
                    currency={currency}
                    protectedLabel={data.protectedLabel}
                />
                <!-- Desktop-only donate buttons -->
                <div
                    class="hidden lg:flex flex-col gap-2 px-5 py-4 border-b border-border"
                >
                    <button
                        onclick="window.dispatchEvent(new CustomEvent('open-stripe'))"
                        class="w-full px-5 py-3 rounded-[10px] text-[13px] font-semibold tracking-[0.3px] cursor-pointer border-none bg-accent text-white"
                        >{data.cta.primary}</button
                    >
                    <button
                        onclick="window.dispatchEvent(new CustomEvent('trigger-share'))"
                        class="w-full px-5 py-3 rounded-[10px] text-[13px] font-semibold cursor-pointer bg-transparent border border-border text-text-mid"
                    >
                        {data.cta.secondary}
                    </button>
                </div>
                <FundingSection />
                <OrganizerSection
                    name={data.organizer.name}
                    location={data.organizer.location}
                />
                <TrustSection items={data.trust} />
            </div>
        </div>

        <!-- Footer -->
        <div class="max-w-5xl mx-auto lg:px-6">
            <FooterLinks siteName={data.nav.siteName} />
        </div>

        <!-- Mobile-only sticky bottom CTA -->
        <div class="lg:hidden">
            <StickyBottom
                primaryLabel={data.cta.primary}
                secondaryLabel={data.cta.secondary}
                goal={goal}
                currency={currency}
            />
        </div>

        <StripeSheet />
        <ShareDialog title={data.title} text={data.subtitle} />
    </div>
</BaseLayout>
